import { useEffect } from "react";

export default function useVolumeMprLoader({
  enabled,
  setLoading,
  setError,
  onReady,
}) {
  useEffect(() => {
    if (!enabled) return;

    setLoading?.(false);
    setError?.("Volume MPR mode is not available in this build.");
    onReady?.();
  }, [enabled, setLoading, setError, onReady]);
}
